# Per-deal artifacts contain VC research and should never be committed
deals/

# Playwright MCP runtime logs and page snapshots — tool output, not source
.playwright-mcp/

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/

# Python bytecode cache
__pycache__/
*.pyc

# Local git worktrees
.worktrees/

# Local Claude Code session state (settings, installed skills/commands)
# .claude-plugin/ is the published plugin manifest and IS tracked.
.claude/

# Local Codex skill installations (the published plugin manifest .codex-plugin/ IS tracked)
.codex/skills/
